# Optional API origin. Leave empty to use the same browser origin.
VITE_API_ORIGIN=

# API prefix used by src/api/http.js.
VITE_API_PREFIX=/api/v1

# Safe local default user id for development only.
VITE_USER_ID=10001

# Frontend path used by the session chat to reach the DeepSeek proxy.
VITE_DEEPSEEK_PROXY_PATH=/deepseek/chat/completions

# Server-side only. Do not prefix with VITE_ and do not commit real keys.
# Vite dev proxy reads this variable and sends it as:
# Authorization: Bearer <MERITCO_DS_KEY>
# User-facing credential name: Meritco-DS-Key.
MERITCO_DS_KEY=
DEEPSEEK_API_ORIGIN=https://api.deepseek.com

# Server-side only. Workbench database credentials must not be exposed to Vite/frontend code.
WORKBENCH_MYSQL_DEV_BACKEND_PASSWORD=

# Server-side only. Optional Tencent WeCom credentials for workbench document/sheet sync.
WORKBENCH_WECOM_CORP_ID=
# Optional. Keep if a later endpoint needs the application id.
WORKBENCH_WECOM_AGENT_ID=
WORKBENCH_WECOM_SECRET=
# Optional default space id used when listing files without a manual selector.
WORKBENCH_WECOM_DEFAULT_SPACE_ID=
# Optional comma-separated list: spaceid:display_name,spaceid2:display_name2
WORKBENCH_WECOM_SPACES=
